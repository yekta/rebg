{
  "manifestVersion": 5,
  "id": "com.yekta.birefnet.removebg",
  "name": "BiRefNet Local Remove BG",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0.0"
  },
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/plugin-dark.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium"
      ],
      "species": [
        "generic"
      ]
    },
    {
      "width": 23,
      "height": 23,
      "path": "icons/plugin-light.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "light",
        "lightest"
      ],
      "species": [
        "generic"
      ]
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "birefnetPanel",
      "label": {
        "default": "BiRefNet Remove BG"
      },
      "minimumSize": {
        "width": 280,
        "height": 220
      },
      "maximumSize": {
        "width": 720,
        "height": 1000
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 260
      },
      "preferredFloatingSize": {
        "width": 340,
        "height": 280
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/plugin-dark.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "darkest",
            "dark",
            "medium"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/plugin-light.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "light",
            "lightest"
          ]
        }
      ]
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "http://localhost:8765",
        "http://127.0.0.1",
        "http://127.0.0.1:8765",
        "http://localhost",
        "https://localhost:8765",
        "https://127.0.0.1:8765"
      ]
    }
  }
}
